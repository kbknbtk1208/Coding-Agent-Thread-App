  },
  "registries": {
    "@systaliko-ui": "https://systaliko-ui.vercel.app/r/{name}.json",
    "@scrollxui": "https://www.scrollxui.dev/registry/{name}.json",
    "@odysseyui": "https://www.odysseyui.com/r/{name}.json"
  }
}
